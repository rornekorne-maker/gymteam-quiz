      <a href="https://gymteam.ru/l/fatburning" class="btn-primary" onclick="event.preventDefault(); alert('Здесь будет переход на страницу курса');">
        Перейти на страницу курса
        <svg viewBox="0 0 20 20" fill="none">
          <path d="M4 10h12M16 10l-5-5M16 10l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
