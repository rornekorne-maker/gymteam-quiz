<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Жиросжигающий — узнай свой тип</title>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --black: #0E0E10;
  --black-2: #1A1A1F;
  --red: #EE2737;
  --red-dark: #C81E2C;
  --red-soft: #FFF0F1;
  --pink: #EE4777;
  --blue: #3CB4E5;
  --gray-50: #F5F5F7;
  --gray-100: #ECECEE;
  --gray-200: #D8D8DC;
  --gray-400: #8E8E93;
  --gray-600: #4A4A4F;
  --white: #FFFFFF;
  --green: #1B7A3E;
  --green-bg: #E6F4EA;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Manrope', sans-serif;
  background: var(--white);
  color: var(--black);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

.h-display {
  font-family: 'Oswald', 'Manrope', sans-serif;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: -0.005em;
  line-height: 0.95;
}

.screen { display: none; }
.screen.active { display: block; animation: fadeIn 0.3s ease both; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

.container { max-width: 420px; margin: 0 auto; padding: 0 20px; }

/* ─── HEADER ─── */
.top-bar {
  background: var(--black);
  padding: 14px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
}
.top-bar img { height: 26px; display: block; }
.top-tag {
  font-size: 10px;
  font-weight: 700;
  color: rgba(255,255,255,0.5);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

/* ─── LANDING (screen-0) ─── */
.lp-hero {
  background: var(--black);
  position: relative;
  overflow: hidden;
}
.lp-hero-img {
  width: 100%;
  height: 320px;
  object-fit: cover;
  object-position: center 25%;
  display: block;
  filter: brightness(0.55) contrast(1.1) saturate(0.85);
}
.lp-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(14,14,16,0.2) 0%, rgba(14,14,16,0.7) 70%, var(--black) 100%);
}
.lp-hero-content {
  padding: 24px 20px 28px;
  position: relative;
  z-index: 2;
  margin-top: -120px;
}
.lp-eyebrow {
  display: inline-block;
  font-size: 10px;
  font-weight: 800;
  color: var(--red);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 14px;
  padding: 5px 11px;
  background: rgba(238,39,55,0.12);
  border: 1px solid rgba(238,39,55,0.4);
}
.lp-h1 {
  font-family: 'Oswald', sans-serif;
  font-weight: 700;
  font-size: 32px;
  text-transform: uppercase;
  line-height: 0.98;
  color: var(--white);
  margin-bottom: 22px;
  letter-spacing: -0.01em;
}
.lp-h1 .accent { color: var(--red); }

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  background: var(--red);
  color: var(--white);
  font-family: 'Oswald', sans-serif;
  font-size: 17px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 18px 24px;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.15s, transform 0.12s;
  -webkit-tap-highlight-color: transparent;
}
.btn-primary:hover { background: var(--red-dark); }
.btn-primary:active { transform: scale(0.98); }
.btn-primary:disabled { background: var(--gray-200); color: var(--gray-400); cursor: not-allowed; }
.btn-primary svg { width: 20px; height: 20px; flex-shrink: 0; }

/* problems */
.lp-section { padding: 28px 20px; }
.lp-problems {
  background: var(--red-soft);
  border-top: 4px solid var(--red);
}
.lp-section-label {
  font-size: 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--red);
  margin-bottom: 14px;
}
.lp-h2 {
  font-family: 'Oswald', sans-serif;
  font-weight: 700;
  font-size: 26px;
  text-transform: uppercase;
  line-height: 1;
  color: var(--black);
  margin-bottom: 22px;
}
.lp-h2 .accent { color: var(--red); }

.prob-list { display: flex; flex-direction: column; gap: 10px; }
.prob-card {
  background: var(--white);
  padding: 14px 14px 14px 14px;
  display: flex;
  align-items: center;
  gap: 14px;
  border-left: 3px solid var(--red);
}
.prob-icon {
  width: 38px; height: 38px;
  background: var(--red-soft);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
  flex-shrink: 0;
}
.prob-text { font-size: 13.5px; font-weight: 600; color: #2A1015; line-height: 1.35; }

/* guide */
.lp-guide { background: var(--gray-50); }
.lp-guide-text { font-size: 15px; line-height: 1.65; color: var(--black); }
.lp-guide-text strong { font-weight: 800; }

/* plan */
.lp-plan { background: var(--white); padding-bottom: 24px; }
.lp-plan-intro { font-size: 14px; color: var(--gray-600); margin-bottom: 18px; font-weight: 500; }
.check-list { display: flex; flex-direction: column; gap: 14px; margin-bottom: 26px; }
.check-row { display: flex; align-items: flex-start; gap: 12px; }
.check-mark {
  width: 24px; height: 24px;
  background: var(--black);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}
.check-mark svg { width: 12px; height: 12px; }
.check-body { flex: 1; }
.check-title { font-size: 14px; font-weight: 700; color: var(--black); line-height: 1.35; margin-bottom: 2px; }
.check-sub { font-size: 12.5px; color: var(--gray-600); font-weight: 500; line-height: 1.4; }

/* avoid */
.lp-avoid {
  padding: 16px 20px;
  background: var(--white);
  text-align: center;
  border-top: 1px solid var(--gray-100);
}
.lp-avoid-text { font-size: 12px; color: var(--gray-600); line-height: 1.55; }
.lp-avoid-text strong { color: var(--red); font-weight: 800; }

/* success */
.lp-success {
  margin: 0 20px 24px;
  background: var(--green-bg);
  padding: 14px 16px;
  display: flex;
  align-items: flex-start;
  gap: 10px;
  border-left: 3px solid var(--green);
}
.lp-success-star { font-size: 18px; line-height: 1; flex-shrink: 0; }
.lp-success-text { font-size: 12.5px; font-weight: 600; color: #0F3D1F; line-height: 1.5; }

/* ─── QUIZ ─── */
.quiz-bg {
  background: var(--white);
  min-height: 100vh;
}
.quiz-progress-bar {
  background: var(--gray-100);
  height: 4px;
  position: sticky;
  top: 54px;
  z-index: 99;
}
.quiz-progress-fill {
  height: 100%;
  background: var(--red);
  width: 0;
  transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.quiz-wrap { padding: 28px 20px 36px; }
.quiz-step {
  font-family: 'Oswald', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.16em;
  color: var(--red);
  text-transform: uppercase;
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.quiz-step::before {
  content: '';
  width: 18px; height: 1.5px;
  background: var(--red);
  display: inline-block;
}
.quiz-question {
  font-family: 'Oswald', sans-serif;
  font-weight: 700;
  font-size: 26px;
  text-transform: uppercase;
  line-height: 1.05;
  color: var(--black);
  margin-bottom: 24px;
  letter-spacing: -0.005em;
}
.quiz-name { color: var(--red); }

.field-wrap { margin-bottom: 22px; }
.field-input {
  width: 100%;
  padding: 16px 18px;
  border: 2px solid var(--gray-200);
  background: var(--white);
  font-family: 'Manrope', sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: var(--black);
  outline: none;
  transition: border-color 0.15s;
}
.field-input:focus { border-color: var(--black); }
.field-input::placeholder { color: var(--gray-400); font-weight: 500; }
.field-error {
  font-size: 12px;
  color: var(--red);
  margin-top: 8px;
  font-weight: 600;
  display: none;
}
.field-error.show { display: block; }
.field-hint {
  font-size: 11.5px;
  color: var(--gray-400);
  margin-top: 10px;
  font-weight: 500;
  text-align: center;
  line-height: 1.5;
}

.options { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
.option-card {
  background: var(--white);
  border: 2px solid var(--gray-200);
  padding: 15px 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 12px;
  transition: border-color 0.15s, background 0.15s, transform 0.12s;
  -webkit-tap-highlight-color: transparent;
  text-align: left;
}
.option-card:hover { border-color: var(--black); }
.option-card:active { transform: scale(0.99); }
.option-card.selected {
  border-color: var(--red);
  background: var(--red-soft);
}
.option-radio {
  width: 22px; height: 22px;
  border: 2px solid var(--gray-200);
  border-radius: 50%;
  flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  transition: border-color 0.15s, background 0.15s;
}
.option-card.selected .option-radio {
  border-color: var(--red);
  background: var(--red);
}
.option-card.selected .option-radio::after {
  content: '';
  width: 8px; height: 8px;
  background: var(--white);
  border-radius: 50%;
}
.option-text {
  font-size: 14.5px;
  font-weight: 600;
  color: var(--black);
  line-height: 1.35;
}

/* ─── RESULT ─── */
.result-bg { background: var(--gray-50); padding-bottom: 48px; }
.result-hero {
  background: var(--black);
  color: var(--white);
  padding: 36px 20px 32px;
}
.result-eyebrow {
  font-size: 10px;
  font-weight: 800;
  letter-spacing: 0.16em;
  color: var(--red);
  text-transform: uppercase;
  margin-bottom: 10px;
}
.result-greeting {
  font-family: 'Oswald', sans-serif;
  font-weight: 700;
  font-size: 24px;
  text-transform: uppercase;
  margin-bottom: 18px;
  line-height: 1.05;
}
.result-greeting .fire { color: var(--red); }
.result-type-box {
  background: var(--red);
  padding: 4px 12px;
  display: inline-block;
  margin-bottom: 14px;
}
.result-type-label {
  font-family: 'Oswald', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--white);
}
.result-type-name {
  font-family: 'Oswald', sans-serif;
  font-weight: 700;
  font-size: 34px;
  text-transform: uppercase;
  line-height: 1;
  margin-bottom: 18px;
  color: var(--white);
  letter-spacing: -0.01em;
}
.result-diag {
  font-size: 15px;
  line-height: 1.6;
  color: rgba(255,255,255,0.85);
  font-weight: 500;
}
.result-diag strong { color: var(--white); font-weight: 700; }

.result-card {
  background: var(--white);
  margin: 0 20px;
  padding: 24px 20px;
  border-top: 4px solid var(--red);
  margin-top: -1px;
}
.result-card h3 {
  font-family: 'Oswald', sans-serif;
  font-size: 20px;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 8px;
  color: var(--black);
  line-height: 1.1;
}
.result-card p {
  font-size: 14px;
  color: var(--gray-600);
  line-height: 1.55;
  margin-bottom: 18px;
  font-weight: 500;
}
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  background: var(--black);
  color: var(--white);
  font-family: 'Oswald', sans-serif;
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 16px 22px;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.15s;
  -webkit-tap-highlight-color: transparent;
}
.btn-secondary:hover { background: var(--gray-600); }
.btn-secondary svg { width: 16px; height: 16px; }

.result-bridge {
  background: var(--white);
  margin: 16px 20px 0;
  padding: 24px 20px;
  border-top: 1px solid var(--gray-100);
}
.bridge-eyebrow {
  font-size: 10px;
  font-weight: 800;
  color: var(--red);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 10px;
}
.bridge-h2 {
  font-family: 'Oswald', sans-serif;
  font-weight: 700;
  font-size: 24px;
  text-transform: uppercase;
  line-height: 1.05;
  color: var(--black);
  margin-bottom: 14px;
}
.bridge-text {
  font-size: 14px;
  line-height: 1.6;
  color: var(--gray-600);
  margin-bottom: 18px;
  font-weight: 500;
}

.course-features {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 18px;
  padding: 16px;
  background: var(--gray-50);
}
.course-feat-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 13.5px;
  font-weight: 600;
  color: var(--black);
  line-height: 1.4;
}
.course-feat-row .icon { font-size: 16px; flex-shrink: 0; line-height: 1.2; }

.bridge-personal {
  background: var(--red-soft);
  border-left: 3px solid var(--red);
  padding: 14px 16px;
  margin-bottom: 22px;
}
.bridge-personal-label {
  font-size: 10px;
  font-weight: 800;
  color: var(--red);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 6px;
}
.bridge-personal-text {
  font-size: 13.5px;
  line-height: 1.55;
  color: #2A1015;
  font-weight: 600;
}

.proof-strip {
  background: var(--black);
  color: var(--white);
  padding: 18px 20px;
  margin-top: 20px;
  text-align: center;
}
.proof-num {
  font-family: 'Oswald', sans-serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--red);
  letter-spacing: 0.02em;
}
.proof-txt {
  font-size: 11.5px;
  font-weight: 600;
  color: rgba(255,255,255,0.7);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-top: 2px;
}

/* footer */
.foot {
  background: var(--black);
  padding: 18px 20px;
  text-align: center;
}
.foot img { height: 22px; opacity: 0.6; margin-bottom: 8px; }
.foot-text {
  font-size: 11px;
  color: rgba(255,255,255,0.4);
  line-height: 1.6;
}
.foot-text a { color: var(--red); text-decoration: none; }

/* utility */
.spacer-12 { height: 12px; }

@media (max-width: 380px) {
  .lp-h1 { font-size: 28px; }
  .quiz-question { font-size: 23px; }
  .result-type-name { font-size: 28px; }
}
</style>
</head>
<body>

<header class="top-bar">
  <img src="logo.svg" alt="GymTeam">
  <div class="top-tag" id="topTag">Бесплатный тест</div>
</header>

<!-- ═══════════════ LANDING ═══════════════ -->
<section class="screen active" id="screen-landing">

  <div class="lp-hero">
    <img src="hero.png" alt="Женщина дома, уставший взгляд" class="lp-hero-img">
    <div class="lp-hero-overlay"></div>
    <div class="lp-hero-content">
      <span class="lp-eyebrow">Бесплатная диагностика</span>
      <h1 class="lp-h1">Узнай, почему твой жир <span class="accent">не уходит</span>, даже когда ты всё делаешь правильно</h1>
      <button class="btn-primary" onclick="startQuiz()">
        Пройти тест
        <svg viewBox="0 0 20 20" fill="none">
          <path d="M4 10h12M16 10l-5-5M16 10l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="lp-section lp-problems">
    <div class="lp-section-label">Узнаёшь себя?</div>
    <h2 class="lp-h2">Ты <span class="accent">не одна</span>, кто застрял</h2>
    <div class="prob-list">
      <div class="prob-card">
        <div class="prob-icon">📉</div>
        <div class="prob-text">Вес стоит неделями — даже при правильном питании</div>
      </div>
      <div class="prob-card">
        <div class="prob-icon">😞</div>
        <div class="prob-text">«Почему у других получается, а у меня нет?»</div>
      </div>
      <div class="prob-card">
        <div class="prob-icon">🍕</div>
        <div class="prob-text">Вечерние срывы и чувство вины после</div>
      </div>
    </div>
  </div>

  <div class="lp-section lp-guide">
    <div class="lp-section-label" style="color: var(--gray-600);">Ты не одна</div>
    <p class="lp-guide-text"><strong>Тебя понимают.</strong> Этот тест составили тренеры, которые 15 лет ищут причину, а не вешают ярлык «ленивая».</p>
  </div>

  <div class="lp-section lp-plan">
    <div class="lp-section-label" style="color: var(--gray-600);">Что получишь</div>
    <h2 class="lp-h2">2 минуты — <span class="accent">и всё ясно</span></h2>
    <p class="lp-plan-intro">Пройди короткий тест и узнай:</p>
    <div class="check-list">
      <div class="check-row">
        <div class="check-mark">
          <svg viewBox="0 0 12 12" fill="none"><path d="M2.5 6l2.5 2.5 4.5-5" stroke="#fff" stroke-width="1.7" stroke-linecap="square"/></svg>
        </div>
        <div class="check-body">
          <div class="check-title">Какой у тебя тип жиросжигания</div>
          <div class="check-sub">И почему прошлые методы не работали</div>
        </div>
      </div>
      <div class="check-row">
        <div class="check-mark">
          <svg viewBox="0 0 12 12" fill="none"><path d="M2.5 6l2.5 2.5 4.5-5" stroke="#fff" stroke-width="1.7" stroke-linecap="square"/></svg>
        </div>
        <div class="check-body">
          <div class="check-title">5 продуктов, которые тайно убивают талию</div>
          <div class="check-sub">PDF-гайд от тренеров — бесплатно</div>
        </div>
      </div>
      <div class="check-row">
        <div class="check-mark">
          <svg viewBox="0 0 12 12" fill="none"><path d="M2.5 6l2.5 2.5 4.5-5" stroke="#fff" stroke-width="1.7" stroke-linecap="square"/></svg>
        </div>
        <div class="check-body">
          <div class="check-title">Что делать именно в твоём случае</div>
          <div class="check-sub">Чтобы сдвинуть вес с мёртвой точки</div>
        </div>
      </div>
    </div>
    <button class="btn-primary" onclick="startQuiz()">
      Пройти тест
      <svg viewBox="0 0 20 20" fill="none">
        <path d="M4 10h12M16 10l-5-5M16 10l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
      </svg>
    </button>
  </div>

  <div class="lp-avoid">
    <p class="lp-avoid-text"><strong>Не начинай ещё одну диету,</strong> пока не узнаешь свой тип жиросжигания. Без диагностики любой план — лотерея.</p>
  </div>

  <div class="lp-success">
    <span class="lp-success-star">✨</span>
    <p class="lp-success-text">После теста ты получишь персональный разбор и чёткое понимание, что делать дальше. Без гаданий и жёстких ограничений.</p>
  </div>

</section>

<!-- ═══════════════ QUIZ ═══════════════ -->
<section class="screen" id="screen-quiz">
  <div class="quiz-progress-bar"><div class="quiz-progress-fill" id="progressFill"></div></div>
  <div class="container">
    <div class="quiz-wrap">

      <!-- name input -->
      <div id="step-name" class="quiz-block">
        <div class="quiz-step">Знакомство</div>
        <h2 class="quiz-question">Привет! Давай <span class="quiz-name">познакомимся</span>. Как тебя зовут?</h2>
        <div class="field-wrap">
          <input type="text" class="field-input" id="nameInput" placeholder="Ваше имя" autocomplete="given-name" maxlength="40">
          <div class="field-error" id="nameError">Введите имя — минимум 2 буквы</div>
        </div>
        <button class="btn-primary" id="nameBtn" onclick="submitName()">
          Дальше
          <svg viewBox="0 0 20 20" fill="none">
            <path d="M4 10h12M16 10l-5-5M16 10l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
          </svg>
        </button>
      </div>

      <!-- questions container — built dynamically -->
      <div id="step-question" style="display:none;">
        <div class="quiz-step" id="qStep">Вопрос 1 из 7</div>
        <h2 class="quiz-question" id="qTitle"></h2>
        <div class="options" id="qOptions"></div>
        <button class="btn-primary" id="qBtn" disabled onclick="submitAnswer()">
          Дальше
          <svg viewBox="0 0 20 20" fill="none">
            <path d="M4 10h12M16 10l-5-5M16 10l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
          </svg>
        </button>
      </div>

      <!-- email -->
      <div id="step-email" style="display:none;">
        <div class="quiz-step">Последний шаг</div>
        <h2 class="quiz-question"><span class="quiz-name" id="emailName">Имя</span>!</h2>
        <p style="font-size:15px;color:var(--gray-600);line-height:1.5;margin-bottom:22px;font-weight:500;">Куда прислать твой результат и PDF «5 продуктов, которые убивают талию»?</p>
        <div class="field-wrap">
          <input type="email" class="field-input" id="emailInput" placeholder="your@email.com" autocomplete="email">
          <div class="field-error" id="emailError">Введите корректный email</div>
          <p class="field-hint">🔒 Без спама. Только результат и полезные советы.</p>
        </div>
        <button class="btn-primary" id="emailBtn" onclick="submitEmail()">
          Получить результат
          <svg viewBox="0 0 20 20" fill="none">
            <path d="M4 10h12M16 10l-5-5M16 10l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
          </svg>
        </button>
      </div>

    </div>
  </div>
</section>

