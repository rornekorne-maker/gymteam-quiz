  <img src="logo.svg" alt="GymTeam">
  <p class="foot-text">Программы чемпионки России по фитнес-бикини<br><a href="#">gymteam.ru</a></p>
</footer>

<script>
const STORAGE_KEY = 'gymteam_quiz_state';

const QUESTIONS = [
  {
    id: 'q1',
    title: 'Что ты хочешь <span class="quiz-name">в первую очередь</span>, {NAME}?',
    options: [
      { text: 'Похудеть на 5–10 кг',                          weights: { A: 2, B: 0, V: 1, G: 1 } },
      { text: 'Убрать живот и бока',                          weights: { A: 1, B: 0, V: 3, G: 2 } },
      { text: 'Подтянуть всё тело, убрать дряблость',         weights: { A: 0, B: 2, V: 1, G: 1 } },
      { text: 'Увидеть рельеф и мышечный тонус',              weights: { A: 0, B: 3, V: 0, G: 1 } }
    ]
  },
  {
    id: 'q2',
    title: 'Что ты <span class="quiz-name">уже пробовала</span>, чтобы похудеть?',
    options: [
      { text: 'Диеты, голодовки, детоксы',                    weights: { A: 4, B: 0, V: 1, G: 1 } },
      { text: 'Марафоны и онлайн-программы',                  weights: { A: 1, B: 1, V: 1, G: 2 } },
      { text: 'Тренажёрный зал, кардио',                      weights: { A: 0, B: 4, V: 0, G: 1 } },
      { text: 'Всё вместе, и ничего не сработало надолго',    weights: { A: 2, B: 1, V: 3, G: 1 } },
      { text: 'Почти ничего, я новичок',                      weights: { A: 0, B: 0, V: 1, G: 1 } }
    ]
  },
  {
    id: 'q3',
    title: 'Как часто ты <span class="quiz-name">тренируешься</span> сейчас?',
    options: [
      { text: 'Вообще не тренируюсь',                         weights: { A: 1, B: 0, V: 2, G: 1 } },
      { text: '1–2 раза в неделю, когда есть силы',           weights: { A: 0, B: 0, V: 2, G: 2 } },
      { text: '3–4 раза в неделю стабильно',                  weights: { A: 0, B: 1, V: 1, G: 2 } },
      { text: '5+ раз, но результата нет',                    weights: { A: 1, B: 4, V: 2, G: 0 } }
    ]
  },
  {
    id: 'q4',
    title: 'Что лучше всего описывает <span class="quiz-name">твоё питание</span>?',
    options: [
      { text: 'Стараюсь есть правильно, но срываюсь вечером', weights: { A: 0, B: 0, V: 4, G: 2 } },
      { text: 'Считаю калории, всё записываю',                weights: { A: 3, B: 1, V: 1, G: 1 } },
      { text: 'Ем мало, но вес стоит',                        weights: { A: 5, B: 0, V: 1, G: 1 } },
      { text: 'Питаюсь нормально, не понимаю, почему не худею', weights: { A: 0, B: 0, V: 1, G: 5 } }
    ]
  },
  {
    id: 'q5',
    title: 'Когда ты <span class="quiz-name">срываешься</span> с питания?',
    options: [
      { text: 'Вечером, после тяжёлого дня',                  weights: { A: 0, B: 0, V: 4, G: 2 } },
      { text: 'На выходных, когда режим ломается',            weights: { A: 0, B: 0, V: 1, G: 3 } },
      { text: 'В компании / на праздниках',                   weights: { A: 0, B: 0, V: 2, G: 2 } },
      { text: 'Я не срываюсь, я просто не худею',             weights: { A: 3, B: 1, V: 0, G: 3 } }
    ]
  },
  {
    id: 'q6',
    title: 'Что беспокоит больше всего <span class="quiz-name">в зоне живота</span>?',
    options: [
      { text: 'Постоянное вздутие и тяжесть',                 weights: { A: 1, B: 0, V: 2, G: 4 } },
      { text: 'Жир на животе, который не уходит ни на каких диетах', weights: { A: 1, B: 0, V: 4, G: 2 } },
      { text: 'Дряблость и растянутая кожа',                  weights: { A: 1, B: 3, V: 1, G: 0 } },
      { text: 'Талия есть, но хочется рельеф и кубики',       weights: { A: 0, B: 3, V: 0, G: 1 } }
    ]
  },
  {
    id: 'q7',
    title: 'Сколько <span class="quiz-name">времени</span> готова уделять тренировкам в день?',
    options: [
      { text: '15–20 минут, больше не выкроить',              weights: { A: 1, B: 0, V: 2, G: 1 } },
      { text: '30–40 минут стабильно',                        weights: { A: 1, B: 1, V: 1, G: 1 } },
      { text: '45–60 минут, готова вкладываться',             weights: { A: 0, B: 2, V: 0, G: 1 } },
      { text: 'Зависит от дня, нужен гибкий план',            weights: { A: 1, B: 0, V: 2, G: 2 } }
    ]
  }
];

const TYPES = {
  A: {
    name: 'Голодная диета',
    diag: 'Твой жир не уходит, потому что ты <strong>ешь слишком мало</strong>. Организм включил режим энергосбережения и держит каждый грамм. Метаболизм замедлен. Узнаёшь себя?',
    personal: 'В курсе есть блок по разгону метаболизма — ты перестанешь голодать и начнёшь худеть.'
  },
  B: {
    name: 'Кардио-наркоманка',
    diag: 'Ты делаешь много кардио, теряешь мышцы — а жир остаётся на местах. Без мышечного каркаса <strong>метаболизм низкий</strong>. Жиру нечем сжигаться. Узнаёшь себя?',
    personal: 'В курсе 3 класса тренировок, включая силовой — ты нарастишь мышцы, которые жгут жир в покое.'
  },
  V: {
    name: 'Гормональные качели',
    diag: 'Твой главный враг — <strong>кортизол</strong>. Стресс, недосып, тренировки на износ — тело включает режим «энергосбережения». Жир с живота не уходит, даже на дефиците. Узнаёшь себя?',
    personal: 'В курсе есть блок про кортизол и восстановление — ты уберёшь жир с живота без изнурительных тренировок.'
  },
  G: {
    name: 'Скрытый сахар',
    diag: 'Ты думаешь, что питаешься правильно, но «полезные» перекусы и <strong>скрытый сахар</strong> тормозят прогресс. Организм на инсулиновых качелях и не отдаёт жир. Узнаёшь себя?',
    personal: 'В курсе план питания без скрытого сахара — ты уберёшь инсулиновые качели и запустишь жиросжигание.'
  }
};

let state = {
  name: '',
  answers: {},
  qIndex: 0,
  email: ''
};

function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      const saved = JSON.parse(raw);
      if (saved && typeof saved === 'object') state = { ...state, ...saved };
    }
  } catch (e) {}
}

function saveState() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch (e) {}
}

function clearState() {
  try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0, 0);
}

function setProgress(pct) {
  document.getElementById('progressFill').style.width = pct + '%';
}

function setTopTag(text) {
  document.getElementById('topTag').textContent = text;
}

function startQuiz() {
  if (state.name) {
    if (state.qIndex < 7) renderQuestion();
    else showEmail();
  } else {
    showScreen('screen-quiz');
    showNameStep();
  }
}

function showNameStep() {
  document.getElementById('step-name').style.display = 'block';
  document.getElementById('step-question').style.display = 'none';
  document.getElementById('step-email').style.display = 'none';
  setProgress(5);
  setTopTag('Знакомство');
  setTimeout(() => document.getElementById('nameInput').focus(), 100);
}

function submitName() {
  const input = document.getElementById('nameInput');
  const errEl = document.getElementById('nameError');
  const value = input.value.trim();
  const valid = /^[А-Яа-яЁёA-Za-z\s\-]{2,}$/.test(value);
  if (!valid) {
    errEl.classList.add('show');
    input.style.borderColor = 'var(--red)';
    return;
  }
  errEl.classList.remove('show');
  input.style.borderColor = '';
  state.name = value;
  state.qIndex = 0;
  saveState();
  showScreen('screen-quiz');
  renderQuestion();
}

function renderQuestion() {
  document.getElementById('step-name').style.display = 'none';
  document.getElementById('step-email').style.display = 'none';
  document.getElementById('step-question').style.display = 'block';
  showScreen('screen-quiz');

  const q = QUESTIONS[state.qIndex];
  const stepNum = state.qIndex + 1;
  document.getElementById('qStep').textContent = `Вопрос ${stepNum} из 7`;
  setTopTag(`Вопрос ${stepNum} из 7`);
  document.getElementById('qTitle').innerHTML = q.title.replace('{NAME}', escapeHtml(state.name));

  const optsEl = document.getElementById('qOptions');
  optsEl.innerHTML = '';
  q.options.forEach((opt, i) => {
    const card = document.createElement('button');
    card.className = 'option-card';
    card.type = 'button';
    card.innerHTML = `
      <span class="option-radio"></span>
      <span class="option-text">${escapeHtml(opt.text)}</span>
    `;
    card.onclick = () => selectOption(i, card);
    optsEl.appendChild(card);
  });

  const btn = document.getElementById('qBtn');
  btn.disabled = true;
  btn.textContent = state.qIndex === 6 ? 'К результату' : 'Дальше';
  btn.innerHTML = (state.qIndex === 6 ? 'К результату' : 'Дальше') + ` <svg viewBox="0 0 20 20" fill="none"><path d="M4 10h12M16 10l-5-5M16 10l-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="square"/></svg>`;

  const pct = Math.round(((state.qIndex + 1) / 9) * 100);
  setProgress(pct);
}

function selectOption(idx, cardEl) {
  document.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
  cardEl.classList.add('selected');
  state.answers['q' + (state.qIndex + 1)] = idx;
  saveState();
  document.getElementById('qBtn').disabled = false;
}

function submitAnswer() {
  if (state.qIndex < 6) {
    state.qIndex++;
    saveState();
    renderQuestion();
  } else {
    state.qIndex = 7;
    saveState();
    showEmail();
  }
}

function showEmail() {
  document.getElementById('step-name').style.display = 'none';
  document.getElementById('step-question').style.display = 'none';
  document.getElementById('step-email').style.display = 'block';
  document.getElementById('emailName').textContent = state.name + '!';
  setTopTag('Email');
  setProgress(95);
  showScreen('screen-quiz');
  setTimeout(() => document.getElementById('emailInput').focus(), 100);
}

function submitEmail() {
  const input = document.getElementById('emailInput');
  const errEl = document.getElementById('emailError');
  const value = input.value.trim();
  const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
  if (!valid) {
    errEl.classList.add('show');
    input.style.borderColor = 'var(--red)';
    return;
  }
  errEl.classList.remove('show');
  input.style.borderColor = '';
  state.email = value;
  saveState();
  showResult();
}

function calcResult() {
  const scores = { A: 0, B: 0, V: 0, G: 0 };
  for (let i = 0; i < QUESTIONS.length; i++) {
    const ansIdx = state.answers['q' + (i + 1)];
    if (ansIdx === undefined) continue;
    const w = QUESTIONS[i].options[ansIdx].weights;
    scores.A += w.A;
    scores.B += w.B;
    scores.V += w.V;
    scores.G += w.G;
  }
  const order = ['V', 'A', 'G', 'B'];
  let winner = order[0];
  let max = scores[winner];
  for (const k of order) {
    if (scores[k] > max) { max = scores[k]; winner = k; }
  }
  return { winner, scores };
}

function showResult() {
  const { winner } = calcResult();
  const t = TYPES[winner];
  document.getElementById('resName').textContent = state.name;
  document.getElementById('resTypeName').textContent = t.name;
  document.getElementById('resDiag').innerHTML = t.diag;
  document.getElementById('resPersonal').textContent = t.personal;
  setTopTag('Твой результат');
  setProgress(100);
  showScreen('screen-result');
  clearState();
}

function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

document.addEventListener('keydown', e => {
  if (e.key !== 'Enter') return;
  const nameStep = document.getElementById('step-name');
  const emailStep = document.getElementById('step-email');
  if (nameStep && nameStep.style.display !== 'none' && document.activeElement && document.activeElement.id === 'nameInput') {
    e.preventDefault();
    submitName();
  }
  if (emailStep && emailStep.style.display !== 'none' && document.activeElement && document.activeElement.id === 'emailInput') {
    e.preventDefault();
    submitEmail();
  }
});

loadState();
</script>

