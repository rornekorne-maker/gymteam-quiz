<section class="screen" id="screen-result">
  <div class="result-bg">

    <div class="result-hero">
      <div class="result-eyebrow">🔥 Твой результат готов</div>
      <h2 class="result-greeting"><span id="resName">Имя</span>, твой результат готов <span class="fire">🔥</span></h2>
      <div class="result-type-box"><span class="result-type-label">Твой тип</span></div>
